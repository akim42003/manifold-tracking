\newlabel{tab:crossmodel}{{5}{9}{Cross-model pass rate and content coherence. All five models are decoder-only transformers with gated FFN blocks. Boldface highlights the Amber case: 65\% pass rate with near-zero content coherence, the clearest demonstration that pass rate alone can be misleading}{table.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.1}Amber 7B: the fake-pass}{9}{subsection.6.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Cross-model pass rate (red) versus content-coherence rate (green). Amber's 65\% pass rate is consistent with a successful replication, but its $<$1\% coherence rate indicates the clusters contain no recognizable linguistic structure. The two metrics agree roughly on Gemma but diverge sharply on Amber.}}{10}{figure.3}\protected@file@percent }
\newlabel{fig:crossmodel}{{3}{10}{Cross-model pass rate (red) versus content-coherence rate (green). Amber's 65\% pass rate is consistent with a successful replication, but its $<$1\% coherence rate indicates the clusters contain no recognizable linguistic structure. The two metrics agree roughly on Gemma but diverge sharply on Amber}{figure.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Cross-model coherence distribution}{10}{subsection.6.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.3}Comparing Gemma and OLMo-2 at matched sizes}{11}{subsection.6.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces $d_{50}$ distributions for Gemma-3 4B (left) and OLMo-2 7B (right), with content-coherent clusters in green and noise in gray. Both models span the full $d_{50}$ range; the claim that OLMo-2 ``implements relations at higher dimensionality'' does not survive this comparison. Gemma's median coherent $d_{50}$ (dashed line, 17) is actually higher than OLMo-2's (12), and 83\% of OLMo-2 coherent clusters fall within the Hernandez band (shaded), versus 55\% for Gemma.}}{11}{figure.4}\protected@file@percent }
\newlabel{fig:d50-dist}{{4}{11}{$d_{50}$ distributions for Gemma-3 4B (left) and OLMo-2 7B (right), with content-coherent clusters in green and noise in gray. Both models span the full $d_{50}$ range; the claim that OLMo-2 ``implements relations at higher dimensionality'' does not survive this comparison. Gemma's median coherent $d_{50}$ (dashed line, 17) is actually higher than OLMo-2's (12), and 83\% of OLMo-2 coherent clusters fall within the Hernandez band (shaded), versus 55\% for Gemma}{figure.4}{}}
