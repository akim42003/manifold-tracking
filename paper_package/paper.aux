\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces OLMo-2 seven-checkpoint trajectory. ``(E)'' Euclidean $k$-means; ``(S-R)'' spherical $k$-means with random init.}}{12}{table.6}\protected@file@percent }
